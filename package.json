{
  "name": "pocaduchy-site",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "fetch:episodes": "node scripts/fetch-episodes.mjs",
    "fetch:subscribers": "node scripts/fetch-subscribers.mjs",
    "build:content": "node scripts/build-content-pages.mjs",
    "prestart": "node scripts/fetch-episodes.mjs && node scripts/fetch-subscribers.mjs && node scripts/build-content-pages.mjs",
    "prebuild": "node scripts/fetch-episodes.mjs && node scripts/fetch-subscribers.mjs && node scripts/build-content-pages.mjs",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "edit": "concurrently -n STRONA,CMS -c blue,magenta \"npm:start\" \"npx decap-server\"",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.2",
    "@docusaurus/faster": "3.10.2",
    "@docusaurus/preset-classic": "3.10.2",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "katex": "^0.16.11",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.2",
    "@docusaurus/types": "3.10.2",
    "concurrently": "^9.1.0",
    "decap-server": "^3.2.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
